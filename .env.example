# Normalization Quest Lab - Environment Configuration
# Copy this file to .env and replace with your values

# Backend (Laravel)
APP_NAME="Normalization Quest Lab"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

# Frontend URL for CORS (production)
FRONTEND_URL=http://localhost:5173

# Database (Supabase/PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password
DB_CHARSET=utf8

# SSL mode for PostgreSQL (require for Supabase, prefer for local)
DB_SSLMODE=prefer

# Supabase credentials (for client-side operations if needed)
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ...

# Database mode: 'supabase' or 'local'
DATABASE_MODE=supabase

BCRYPT_ROUNDS=12
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_SAME_SITE=lax
CSRF_PROTECTION=true

# Sanctum SPA Stateful Domains (comma-separated)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# Cache and Queue
CACHE_DRIVER=array
QUEUE_CONNECTION=sync

# Rate limiting toggle
RATE_LIMITING_ENABLED=true

# Mail Configuration (optional)
MAIL_MAILER=log

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Frontend (React/Vite)
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME="Normalization Quest Lab"
